# Dotfiles Manifest
# Format: app_name|source_path|target_path|enabled|deploy_type
# deploy_type: symlink (default) or copy (for directories that need full copy, like git repos)
tmux|tmux/.tmux.conf|.tmux.conf|true|symlink
zsh|zsh/.zshrc|.zshrc|true|symlink
nvim|nvim|.config/nvim|true|symlink
zsh-config|zsh/.zsh|.zsh|true|symlink
oh-my-posh-themes|oh-my-posh/themes|.config/oh-my-posh/themes|true|symlink
posh-theme|oh-my-posh/posh-theme|.local/bin/posh-theme|true|symlink
tmux-menu|tmux-menu/menus.toml|.config/tmux-menu/menus.toml|true|symlink
fbterm|fbterm/.fbtermrc|.fbtermrc|true|symlink
fbterm-palette|fbterm/breeze-palette.sh|.config/fbterm/breeze-palette.sh|true|symlink
