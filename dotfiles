#!/bin/bash

# Dotfiles Management Script
# A comprehensive tool for managing dotfiles with symlinks

set -euo pipefail

# Configuration
# Resolve symlinks to get real path
SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
DOTFILES_DIR="$(dirname "$SCRIPT_PATH")"
MANIFEST_FILE="$DOTFILES_DIR/.dotfiles-manifest"
BACKUP_DIR="$HOME/.dotfiles-backup"
PACKAGES_DIR="$DOTFILES_DIR/packages"

# Load library modules. `source` reads each file fully at startup, so every
# function is in memory before dispatch — and a self-update that rewrites
# lib/*.sh mid-run can't affect the already-running process.
DOTFILES_LIB="$DOTFILES_DIR/lib"
for _m in common configs git pkg lifecycle; do
    _f="$DOTFILES_LIB/$_m.sh"
    [[ -r "$_f" ]] || { echo "dotfiles: missing library: $_f" >&2; exit 1; }
    # shellcheck source=/dev/null
    source "$_f" || { echo "dotfiles: failed loading library: $_f" >&2; exit 1; }
done
unset _m _f

# Terse usage - one-line per command. Shown when run with no args.
cmd_usage() {
    cat << EOF
${CYAN}Dotfiles Management Tool${NC}

${YELLOW}Usage:${NC}
    dotfiles <command> [options]

${YELLOW}Commands:${NC}
    ${GREEN}status${NC}              Show deployment status of all dotfiles
    ${GREEN}deploy${NC} [--dry-run] [--force]
                        Deploy dotfiles by creating symlinks
    ${GREEN}enable${NC} <app>       Enable a specific dotfile
    ${GREEN}disable${NC} <app>      Disable and remove symlink for a dotfile
    ${GREEN}add${NC} <app> <path>   Add new dotfile to management
    ${GREEN}list${NC}               List all managed dotfiles
    ${GREEN}pkg${NC} <capture|status|sync> [--host <name>] [--prune]
                        Track explicitly-installed packages per host
                        (pacman / AUR / flatpak). capture: record live state;
                        status: show drift; sync: install missing (--prune
                        also removes untracked). Runs only on Arch-family hosts.
    ${GREEN}diff${NC} [--branch <b>] [--details]
                        Preview local state vs origin (default branch: main).
                        Use --details (-d) for full colored diffs.
    ${GREEN}pull${NC} [--branch <b>]  Fast-forward pull from origin (default branch: main)
    ${GREEN}push${NC} [--branch <b>] [--message <msg>]
                        Commit and push to origin (default branch: main).
                        Use --message (-m) to skip prompts and run in one shot.
    ${GREEN}install${NC}            Symlink the dotfiles command into ~/.local/bin
    ${GREEN}update${NC}             Pull latest (self-updates the tool) and re-deploy configs
    ${GREEN}remove${NC}             Remove the command symlink (configs/repo left intact)
    ${GREEN}help${NC}               Open the full manual (rendered with glow if available)
EOF
}

# Help command - render HELP.md (with glow if available)
cmd_help() {
    local help_file="$DOTFILES_DIR/HELP.md"
    if [[ ! -r "$help_file" ]]; then
        log_error "HELP.md not found at $help_file"
        return 1
    fi
    if command -v glow &>/dev/null && [[ -t 1 ]]; then
        glow -p "$help_file"
    else
        cat "$help_file"
    fi
}

# Main command dispatcher
main() {
    # No args → terse usage. Explicit `help` → full manual.
    local cmd="${1:-usage}"
    shift || true

    # Nudge if the repo is behind origin — but not for lifecycle/git verbs
    # (which act on it directly) or the trivial usage/help paths.
    case "$cmd" in
        install|update|remove|pull|push|diff|help|--help|-h|usage) ;;
        *) check_for_update ;;
    esac

    case "$cmd" in
        status)
            cmd_status "$@"
            ;;
        deploy)
            cmd_deploy "$@"
            ;;
        enable)
            cmd_enable "$@"
            ;;
        disable)
            cmd_disable "$@"
            ;;
        add)
            cmd_add "$@"
            ;;
        list)
            cmd_list "$@"
            ;;
        pkg|packages)
            cmd_pkg "$@"
            ;;
        diff)
            cmd_diff "$@"
            ;;
        pull)
            cmd_pull "$@"
            ;;
        push)
            cmd_push "$@"
            ;;
        install)
            cmd_install "$@"
            ;;
        update)
            cmd_update "$@"
            ;;
        remove|uninstall)
            cmd_remove "$@"
            ;;
        usage)
            cmd_usage
            ;;
        help|--help|-h)
            cmd_help
            ;;
        *)
            log_error "Unknown command: $cmd"
            echo
            cmd_usage
            exit 1
            ;;
    esac
}

# Run main function.
# `; exit $?` on the same line is deliberate: pull/update can rewrite this
# script mid-run, and bash reads scripts lazily by byte offset. Parsing
# `main "$@"; exit $?` as one line means exit fires from memory, so no bytes
# are read from the (possibly changed) file after a self-update.
main "$@"; exit $?