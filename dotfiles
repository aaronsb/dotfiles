#!/bin/bash

# Dotfiles Management Script
# A comprehensive tool for managing dotfiles with symlinks

set -euo pipefail

# Configuration
# Resolve symlinks to get real path
SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
DOTFILES_DIR="$(dirname "$SCRIPT_PATH")"
MANIFEST_FILE="$DOTFILES_DIR/.dotfiles-manifest"
BACKUP_DIR="$HOME/.dotfiles-backup"

# Colors for output
RED=$'\033[0;31m'
GREEN=$'\033[0;32m'
YELLOW=$'\033[0;33m'
BLUE=$'\033[0;34m'
PURPLE=$'\033[0;35m'
CYAN=$'\033[0;36m'
NC=$'\033[0m' # No Color

# Logging functions
log_info() {
    echo -e "${BLUE}[INFO]${NC} $1"
}

log_success() {
    echo -e "${GREEN}[SUCCESS]${NC} $1"
}

log_warning() {
    echo -e "${YELLOW}[WARNING]${NC} $1"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

# Initialize manifest if it doesn't exist
init_manifest() {
    if [[ ! -f "$MANIFEST_FILE" ]]; then
        cat > "$MANIFEST_FILE" << EOF
# Dotfiles Manifest
# Format: app_name|source_path|target_path|enabled|deploy_type
# deploy_type: symlink (default) or copy (for directories that need full copy, like git repos)
tmux|tmux/.tmux.conf|.tmux.conf|true|symlink
zsh|zsh/.zshrc|.zshrc|true|symlink
vim|vim/.vimrc|.vimrc|true|symlink
EOF
        log_info "Created manifest file at $MANIFEST_FILE"
    fi
}

# Read manifest and return active entries
read_manifest() {
    grep -v '^#' "$MANIFEST_FILE" 2>/dev/null || true
}

# Check if a dotfile is deployed (symlinked)
is_deployed() {
    local target="$HOME/$1"
    [[ -L "$target" && "$(readlink "$target")" == "$DOTFILES_DIR/$2" ]]
}

# Status command - show state of all dotfiles
cmd_status() {
    init_manifest
    
    echo -e "${CYAN}=== Dotfiles Status ===${NC}"
    echo
    
    local has_issues=false
    
    while IFS='|' read -r app source target enabled deploy_type; do
        [[ -z "$app" ]] && continue

        # Default to symlink for backward compatibility
        deploy_type="${deploy_type:-symlink}"

        local source_path="$DOTFILES_DIR/$source"
        local target_path="$HOME/$target"
        local status=""
        local color=""

        if [[ "$enabled" == "false" ]]; then
            status="DISABLED"
            color="$YELLOW"
        elif [[ ! -f "$source_path" && ! -d "$source_path" ]]; then
            status="SOURCE MISSING"
            color="$RED"
            has_issues=true
        elif [[ "$deploy_type" == "symlink" ]] && is_deployed "$target" "$source"; then
            status="DEPLOYED"
            color="$GREEN"
        elif [[ "$deploy_type" == "copy" && -d "$target_path" && -d "$source_path" ]]; then
            # For copy mode, check if directory exists
            if [[ -d "$target_path/.git" ]]; then
                status="DEPLOYED (git)"
            else
                status="DEPLOYED (copy)"
            fi
            color="$GREEN"
        elif [[ -e "$target_path" ]]; then
            if [[ -L "$target_path" ]]; then
                status="WRONG SYMLINK"
            else
                status="EXISTS (not managed)"
            fi
            color="$YELLOW"
            has_issues=true
        else
            status="NOT DEPLOYED"
            color="$PURPLE"
            has_issues=true
        fi

        printf "%-10s %-30s %b%s%b\n" "$app" "$target" "$color" "$status" "$NC"
    done < <(read_manifest)
    
    echo
    if $has_issues; then
        log_warning "Some dotfiles need attention. Run 'dotfiles deploy' to fix."
    else
        log_success "All enabled dotfiles are properly deployed!"
    fi
}

# Deploy command - create symlinks for all enabled dotfiles
cmd_deploy() {
    local dry_run=false
    local force=false
    
    # Parse options
    while [[ $# -gt 0 ]]; do
        case $1 in
            --dry-run|-n)
                dry_run=true
                shift
                ;;
            --force|-f)
                force=true
                shift
                ;;
            *)
                shift
                ;;
        esac
    done
    
    init_manifest
    
    if $dry_run; then
        log_info "DRY RUN MODE - No changes will be made"
    fi
    
    echo -e "${CYAN}=== Deploying Dotfiles ===${NC}"
    echo
    
    # Create backup directory
    if ! $dry_run; then
        mkdir -p "$BACKUP_DIR"
    fi
    
    while IFS='|' read -r app source target enabled deploy_type; do
        [[ -z "$app" || "$enabled" == "false" ]] && continue

        # Default to symlink for backward compatibility
        deploy_type="${deploy_type:-symlink}"

        local source_path="$DOTFILES_DIR/$source"
        local target_path="$HOME/$target"

        # Skip if source doesn't exist
        if [[ ! -f "$source_path" && ! -d "$source_path" ]]; then
            log_error "$app: Source file or directory missing at $source"
            continue
        fi

        # Check if already properly deployed (for symlink mode)
        if [[ "$deploy_type" == "symlink" ]] && is_deployed "$target" "$source"; then
            log_info "$app: Already deployed"
            continue
        fi

        # For copy mode, check if target is a git repo that needs updating
        if [[ "$deploy_type" == "copy" && -d "$target_path/.git" && -d "$source_path/.git" ]]; then
            if ! $dry_run; then
                log_info "$app: Updating git repository..."
                (cd "$target_path" && git pull) || log_warning "$app: Git pull failed, will re-deploy"
            else
                log_info "$app: Would update git repository"
            fi
            continue
        fi

        # Handle existing files
        if [[ -e "$target_path" || -L "$target_path" ]]; then
            if ! $force; then
                log_warning "$app: Target exists at ~/$target (use --force to override)"
                continue
            fi

            # Backup existing file/directory
            if ! $dry_run; then
                local backup_path="$BACKUP_DIR/$(basename "$target").$(date +%Y%m%d_%H%M%S)"
                mv "$target_path" "$backup_path"
                log_info "$app: Backed up existing to $backup_path"
            else
                log_info "$app: Would backup existing"
            fi
        fi

        # Create parent directory if needed
        local target_dir="$(dirname "$target_path")"
        if [[ ! -d "$target_dir" ]]; then
            if ! $dry_run; then
                mkdir -p "$target_dir"
            else
                log_info "$app: Would create directory $target_dir"
            fi
        fi

        # Deploy based on type
        if [[ "$deploy_type" == "copy" ]]; then
            # Copy mode - recursively copy directory
            if ! $dry_run; then
                cp -r "$source_path" "$target_path"

                # Set permissions for git repo scripts
                if [[ -d "$target_path/.git" ]]; then
                    find "$target_path" -type f -name "*.sh" -exec chmod +x {} \; 2>/dev/null || true
                    [[ -d "$target_path/hooks" ]] && find "$target_path/hooks" -type f -name "*.sh" -exec chmod +x {} \; 2>/dev/null || true
                    [[ -d "$target_path/scripts" ]] && find "$target_path/scripts" -type f -name "*.sh" -exec chmod +x {} \; 2>/dev/null || true
                fi

                log_success "$app: Copied to ~/$target"
            else
                log_info "$app: Would copy to ~/$target"
            fi
        else
            # Symlink mode (default)
            if ! $dry_run; then
                ln -s "$source_path" "$target_path"
                log_success "$app: Deployed to ~/$target"
            else
                log_info "$app: Would deploy to ~/$target"
            fi
        fi
    done < <(read_manifest)
}

# Enable/disable specific dotfiles
cmd_enable() {
    local app="$1"
    [[ -z "$app" ]] && { log_error "Please specify an app to enable"; exit 1; }
    
    init_manifest
    
    # Update manifest
    local temp_file=$(mktemp)
    local found=false

    while IFS='|' read -r m_app source target enabled deploy_type; do
        # Default to symlink for backward compatibility
        deploy_type="${deploy_type:-symlink}"

        if [[ "$m_app" == "$app" ]]; then
            echo "$m_app|$source|$target|true|$deploy_type"
            found=true
            log_success "Enabled $app"
        else
            echo "$m_app|$source|$target|$enabled|$deploy_type"
        fi
    done < <(read_manifest) > "$temp_file"
    
    if ! $found; then
        log_error "App '$app' not found in manifest"
        rm "$temp_file"
        exit 1
    fi
    
    mv "$temp_file" "$MANIFEST_FILE"
}

cmd_disable() {
    local app="$1"
    [[ -z "$app" ]] && { log_error "Please specify an app to disable"; exit 1; }
    
    init_manifest
    
    # Update manifest
    local temp_file=$(mktemp)
    local found=false

    while IFS='|' read -r m_app source target enabled deploy_type; do
        # Default to symlink for backward compatibility
        deploy_type="${deploy_type:-symlink}"

        if [[ "$m_app" == "$app" ]]; then
            echo "$m_app|$source|$target|false|$deploy_type"
            found=true

            # Remove symlink if it exists
            local target_path="$HOME/$target"
            if is_deployed "$target" "$source"; then
                rm "$target_path"
                log_success "Disabled and removed symlink for $app"
            else
                log_success "Disabled $app"
            fi
        else
            echo "$m_app|$source|$target|$enabled|$deploy_type"
        fi
    done < <(read_manifest) > "$temp_file"
    
    if ! $found; then
        log_error "App '$app' not found in manifest"
        rm "$temp_file"
        exit 1
    fi
    
    mv "$temp_file" "$MANIFEST_FILE"
}

# Add new dotfile to management
cmd_add() {
    local app="$1"
    local system_path="$2"
    local repo_path="${3:-$app/$(basename "$system_path")}"
    local deploy_type="${4:-symlink}"

    [[ -z "$app" || -z "$system_path" ]] && {
        log_error "Usage: dotfiles add <app> <system-path> [repo-path] [deploy-type]"
        log_error "  deploy-type: symlink (default) or copy"
        exit 1
    }

    init_manifest

    # Normalize paths
    system_path="${system_path#$HOME/}"
    system_path="${system_path#~/}"

    # Check if already exists
    if grep -q "^$app|" "$MANIFEST_FILE"; then
        log_error "App '$app' already exists in manifest"
        exit 1
    fi

    # Add to manifest
    echo "$app|$repo_path|$system_path|true|$deploy_type" >> "$MANIFEST_FILE"
    log_success "Added $app to manifest (deploy type: $deploy_type)"

    # Offer to capture (only for symlink mode)
    if [[ "$deploy_type" == "symlink" ]]; then
        echo
        read -p "Capture existing file now? [y/N] " -n 1 -r
        echo
        if [[ $REPLY =~ ^[Yy]$ ]]; then
            cmd_capture "$app"
        fi
    fi
}

# List managed dotfiles
cmd_list() {
    init_manifest
    
    echo -e "${CYAN}=== Managed Dotfiles ===${NC}"
    echo
    printf "%-10s %-25s %-25s %-8s %-10s\n" "APP" "SYSTEM PATH" "REPO PATH" "ENABLED" "TYPE"
    printf "%-10s %-25s %-25s %-8s %-10s\n" "---" "-----------" "---------" "-------" "----"

    while IFS='|' read -r app source target enabled deploy_type; do
        [[ -z "$app" || "$app" =~ ^# ]] && continue
        # Default to symlink for backward compatibility
        deploy_type="${deploy_type:-symlink}"
        printf "%-10s %-25s %-25s %-8s %-10s\n" "$app" "~/$target" "$source" "$enabled" "$deploy_type"
    done < <(cat "$MANIFEST_FILE")
}

# Parse common flags from args.
# Sets globals: TARGET_BRANCH (default "main"), DETAILS (default false), MESSAGE (default "").
parse_flags() {
    TARGET_BRANCH="main"
    DETAILS=false
    MESSAGE=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --branch|-b)
                shift
                TARGET_BRANCH="${1:-}"
                [[ -z "$TARGET_BRANCH" ]] && { log_error "--branch requires a name."; exit 1; }
                shift
                ;;
            --details|-d)
                DETAILS=true
                shift
                ;;
            --message|-m)
                shift
                MESSAGE="${1:-}"
                [[ -z "$MESSAGE" ]] && { log_error "--message requires a value."; exit 1; }
                shift
                ;;
            *)
                shift
                ;;
        esac
    done
}

# Require the working tree to be on $1, otherwise bail with hints.
require_on_branch() {
    local target="$1"
    local current
    current="$(git -C "$DOTFILES_DIR" rev-parse --abbrev-ref HEAD)"
    if [[ "$current" != "$target" ]]; then
        log_error "Currently on '$current', not '$target'."
        log_info "Switch:    git -C $DOTFILES_DIR checkout $target"
        log_info "Or target current branch: dotfiles ${FUNCNAME[1]#cmd_} --branch $current"
        exit 1
    fi
}

# Verify the dotfiles dir is a git repo with an 'origin' remote.
# Returns 0 if usable, 1 with a printed reason if not.
require_git_remote() {
    if ! git -C "$DOTFILES_DIR" rev-parse --git-dir &>/dev/null; then
        log_error "$DOTFILES_DIR is not a git repository."
        log_info "Initialize it with: git -C $DOTFILES_DIR init"
        return 1
    fi
    if ! git -C "$DOTFILES_DIR" remote get-url origin &>/dev/null; then
        log_error "No 'origin' remote configured in $DOTFILES_DIR."
        log_info "Add one with: git -C $DOTFILES_DIR remote add origin <url>"
        return 1
    fi
    return 0
}

# Diff command - show local state vs origin/<target> (preview before pull/push)
cmd_diff() {
    require_git_remote || exit 1
    parse_flags "$@"
    local target="$TARGET_BRANCH"

    log_info "Fetching from origin..."
    git -C "$DOTFILES_DIR" fetch origin "$target" --quiet 2>/dev/null \
        || { log_error "Fetch failed (does origin/$target exist?)."; exit 1; }

    local remote_ref="origin/$target"

    local dirty
    dirty="$(git -C "$DOTFILES_DIR" status --porcelain)"
    if [[ -n "$dirty" ]]; then
        echo "${YELLOW}Uncommitted changes:${NC}"
        echo "$dirty" | sed 's/^/    /'
        echo
        if $DETAILS; then
            git -C "$DOTFILES_DIR" diff --color=always
            git -C "$DOTFILES_DIR" diff --cached --color=always
        fi
    fi

    if ! git -C "$DOTFILES_DIR" rev-parse --verify "$remote_ref" &>/dev/null; then
        log_warning "$remote_ref does not exist."
        return 0
    fi

    local ahead behind
    ahead="$(git -C "$DOTFILES_DIR" rev-list --count "$remote_ref..HEAD")"
    behind="$(git -C "$DOTFILES_DIR" rev-list --count "HEAD..$remote_ref")"

    if [[ "$ahead" -eq 0 && "$behind" -eq 0 && -z "$dirty" ]]; then
        log_success "HEAD is in sync with $remote_ref."
        return 0
    fi

    if [[ "$ahead" -gt 0 ]]; then
        echo "${CYAN}Local is $ahead commit(s) ahead of $remote_ref (would push):${NC}"
        git -C "$DOTFILES_DIR" log --oneline "$remote_ref..HEAD" | sed 's/^/    /'
        if $DETAILS; then
            git -C "$DOTFILES_DIR" diff --color=always "$remote_ref..HEAD"
        else
            git -C "$DOTFILES_DIR" diff --stat "$remote_ref..HEAD" | sed 's/^/    /'
        fi
        echo
    fi

    if [[ "$behind" -gt 0 ]]; then
        echo "${CYAN}Remote is $behind commit(s) ahead (would pull):${NC}"
        git -C "$DOTFILES_DIR" log --oneline "HEAD..$remote_ref" | sed 's/^/    /'
        if $DETAILS; then
            git -C "$DOTFILES_DIR" diff --color=always "HEAD..$remote_ref"
        else
            git -C "$DOTFILES_DIR" diff --stat "HEAD..$remote_ref" | sed 's/^/    /'
        fi
        echo
    fi
}

# Pull command - fast-forward pull from origin/<target> into local <target>
cmd_pull() {
    require_git_remote || exit 1
    parse_flags "$@"
    local target="$TARGET_BRANCH"
    require_on_branch "$target"

    log_info "Fetching origin/$target..."
    git -C "$DOTFILES_DIR" fetch origin "$target" --quiet \
        || { log_error "Fetch failed (does origin/$target exist?)."; exit 1; }

    local remote_ref="origin/$target"
    local behind
    behind="$(git -C "$DOTFILES_DIR" rev-list --count "HEAD..$remote_ref")"
    if [[ "$behind" -eq 0 ]]; then
        log_success "Already up to date with $remote_ref."
        return 0
    fi

    local old_head
    old_head="$(git -C "$DOTFILES_DIR" rev-parse HEAD)"

    if ! git -C "$DOTFILES_DIR" merge --ff-only "$remote_ref" --quiet; then
        log_error "Pull failed (likely diverged). Resolve manually."
        exit 1
    fi

    log_success "Pulled $behind commit(s) from $remote_ref:"
    git -C "$DOTFILES_DIR" log --oneline "$old_head..HEAD" | sed 's/^/    /'
    echo
    log_info "Files changed:"
    git -C "$DOTFILES_DIR" diff --stat "$old_head..HEAD" | sed 's/^/    /'
}

# Push command - commit (with prompt) and push current branch to origin/<target>
cmd_push() {
    require_git_remote || exit 1
    parse_flags "$@"
    local target="$TARGET_BRANCH"
    require_on_branch "$target"

    local dirty
    dirty="$(git -C "$DOTFILES_DIR" status --porcelain)"
    if [[ -n "$dirty" ]]; then
        log_info "Uncommitted changes:"
        echo "$dirty" | sed 's/^/    /'
        echo

        local message="$MESSAGE" do_commit=false
        if [[ -n "$message" ]]; then
            do_commit=true
        else
            read -rp "Commit these? [y/N] " -n 1 reply; echo
            if [[ $reply =~ ^[Yy]$ ]]; then
                read -rp "What changed? " message
                if [[ -z "$message" ]]; then
                    log_error "Empty message — aborted."
                    exit 1
                fi
                do_commit=true
            fi
        fi

        if $do_commit; then
            git -C "$DOTFILES_DIR" add -A
            git -C "$DOTFILES_DIR" commit -m "$message" || { log_error "Commit failed."; exit 1; }
            log_success "Committed: $message"
        else
            log_warning "Skipping commit — uncommitted changes will NOT be pushed."
        fi
    fi

    local remote_ref="origin/$target"

    if ! git -C "$DOTFILES_DIR" rev-parse --verify "$remote_ref" &>/dev/null; then
        log_warning "$remote_ref does not exist on origin yet."
        read -rp "Create it (push -u)? [y/N] " -n 1 reply; echo
        [[ ! $reply =~ ^[Yy]$ ]] && { log_info "Aborted."; exit 0; }
        if git -C "$DOTFILES_DIR" push -u origin "$target"; then
            log_success "Pushed and set upstream to $remote_ref."
        else
            log_error "Push failed."
            exit 1
        fi
        return 0
    fi

    local ahead
    ahead="$(git -C "$DOTFILES_DIR" rev-list --count "$remote_ref..HEAD")"
    if [[ "$ahead" -eq 0 ]]; then
        log_success "Already up to date with $remote_ref."
        return 0
    fi

    log_info "Local '$target' is $ahead commit(s) ahead of $remote_ref:"
    git -C "$DOTFILES_DIR" log --oneline "$remote_ref..HEAD" | sed 's/^/    /'
    echo
    if [[ -z "$MESSAGE" ]]; then
        read -rp "Push these commits to $remote_ref? [y/N] " -n 1 reply; echo
        [[ ! $reply =~ ^[Yy]$ ]] && { log_info "Aborted."; exit 0; }
    fi

    if git -C "$DOTFILES_DIR" push origin "$target"; then
        log_success "Pushed."
    else
        log_error "Push failed."
        exit 1
    fi
}

# Help command - render HELP.md (with glow if available)
cmd_help() {
    local help_file="$DOTFILES_DIR/HELP.md"
    if [[ ! -r "$help_file" ]]; then
        log_error "HELP.md not found at $help_file"
        return 1
    fi
    if command -v glow &>/dev/null && [[ -t 1 ]]; then
        glow -p "$help_file"
    else
        cat "$help_file"
    fi
}

# Main command dispatcher
main() {
    local cmd="${1:-help}"
    shift || true
    
    case "$cmd" in
        status)
            cmd_status "$@"
            ;;
        deploy)
            cmd_deploy "$@"
            ;;
        enable)
            cmd_enable "$@"
            ;;
        disable)
            cmd_disable "$@"
            ;;
        add)
            cmd_add "$@"
            ;;
        list)
            cmd_list "$@"
            ;;
        diff)
            cmd_diff "$@"
            ;;
        pull)
            cmd_pull "$@"
            ;;
        push)
            cmd_push "$@"
            ;;
        help|--help|-h)
            cmd_help
            ;;
        *)
            log_error "Unknown command: $cmd"
            echo
            cmd_help
            exit 1
            ;;
    esac
}

# Run main function
main "$@"