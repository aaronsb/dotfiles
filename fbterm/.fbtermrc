#! version:0.1
# fbterm config — mirrors Konsole 'zsh' profile (Monoid Nerd Font Mono + Breeze)

# Nerd Font via fontconfig — Mono variant keeps glyph cells fixed-width.
# Comma-separated = fallback chain.
font_names=Monoid Nerd Font Mono
# NOTE: pixel size (not points). Konsole used 12pt; on the framebuffer this is
# pixels, so tune to taste. 20 is a reasonable start on a hi-res panel.
font_size=20

# default fg/bg are palette indices; we recolor index 0 and 7 to Breeze below.
color_foreground=7
color_background=0

# 256-color terminfo
term=fbterm

# cursor
cursor_shape=block
cursor_interval=500

# let gpm drive the mouse (clickable tmux/vim inside fbterm)
text-encoding=UTF-8
