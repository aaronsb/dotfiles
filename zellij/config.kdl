// ~/.config/zellij/config.kdl  (managed in dotfiles → zellij/config.kdl)
//
// Clean baseline. Zellij's defaults are good, so this only states the few
// things worth being explicit about. The discoverable modal keybindings
// (Ctrl-p pane · Ctrl-t tab · Ctrl-n resize · Ctrl-o session — shown in the
// bottom bar) are kept as defaults. Add custom binds here as needs arise.

// Click panes/tabs; scroll with the wheel.
mouse_mode true

// The whole point: shells that survive detach AND reboot.
//   zellij attach -c <name>   → resume if it exists, create if it doesn't
session_serialization true
serialize_pane_viewport true

// Pane borders + titles.
pane_frames true

default_mode "normal"
