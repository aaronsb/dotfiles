#!/usr/bin/env bash
# mlterm-fontgen — regenerate mlterm-fb's antialiased font-fallback table from
# your tracked intent, using mlterm's own `mlfc` *safely*.
#
# Why this exists:
#   `mlfc <Font>` builds a per-Unicode-block fallback table by probing your
#   installed fonts with fontconfig — genuinely useful. But run bare it (a)
#   defaults the primary to fontconfig's system font (erasing your choice),
#   (b) writes ISO10646_UCS4_1= instead of your DEFAULT=, and (c) clobbers
#   ~/.mlterm/aafont with only a one-shot .bak. That breaks dotfiles tracking.
#
# What this does instead:
#   - Reads the primary font from the DEFAULT= line of your tracked aafont
#     (or takes it as an argument).
#   - Runs the real /usr/bin/mlfc in a throwaway $HOME so it never touches live
#     config, while pointing XDG_DATA_HOME at your real fonts so fontconfig
#     still finds them.
#   - Writes a portable table back to the tracked aafont: DEFAULT= preserved,
#     ISO10646_UCS4_1= (primary) + the per-script U+ fallback ranges.
#
# aafont uses fontconfig FAMILY names -> portable across machines. We deliberately
# do NOT generate font-fb (it uses file paths, which are machine-specific, and is
# unused while use_aafont = true).
#
# Usage:
#   mlterm-fontgen                 # regenerate from the current DEFAULT font
#   mlterm-fontgen "Some Font"     # set a new primary font, then regenerate
set -euo pipefail

DOTFILES="${DOTFILES_DIR:-$HOME/.dotfiles}"
AAFONT="$DOTFILES/mlterm/aafont"
MLFC="${MLFC_BIN:-/usr/bin/mlfc}"
REAL_HOME="$HOME"

[ -x "$MLFC" ] || { echo "mlterm-fontgen: $MLFC not found — install mlterm-fb." >&2; exit 1; }
[ -f "$AAFONT" ] || { echo "mlterm-fontgen: tracked aafont not found at $AAFONT." >&2; exit 1; }

# Resolve the primary font: an argument overrides the tracked DEFAULT line.
if [ "$#" -ge 1 ]; then
  primary="$1"
else
  primary="$(sed -n 's/^[[:space:]]*DEFAULT[[:space:]]*=[[:space:]]*//p' "$AAFONT" | head -1)"
fi
[ -n "$primary" ] || { echo "mlterm-fontgen: no DEFAULT font in $AAFONT and none given." >&2; exit 1; }

echo "mlterm-fontgen: primary font = '$primary'" >&2

# Sandbox: mlfc writes to \$HOME/.mlterm/aafont. Point HOME at a scratch dir so
# live config is untouched; keep XDG_DATA_HOME real so fontconfig still sees
# user-installed fonts (e.g. ~/.local/share/fonts).
scratch="$(mktemp -d)"
trap 'rm -rf "$scratch"' EXIT
mkdir -p "$scratch/.mlterm"

HOME="$scratch" \
  XDG_DATA_HOME="${XDG_DATA_HOME:-$REAL_HOME/.local/share}" \
  XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$REAL_HOME/.config}" \
  "$MLFC" "$primary" >/dev/null

gen="$scratch/.mlterm/aafont"
[ -s "$gen" ] || { echo "mlterm-fontgen: mlfc produced no table (is '$primary' installed?)." >&2; exit 1; }

# Compose the tracked aafont: our header + DEFAULT (intent) + mlfc's primary and
# per-script fallback ranges. Drop mlfc's own '# Permit mlfc to overwrite' header
# so the file isn't self-marked as mlfc-owned.
tmp="$(mktemp)"
{
  echo "# mlterm-fb antialiased font map — GENERATED by mlterm-fontgen."
  echo "# To change your primary font: edit the DEFAULT line below, then re-run"
  echo "#   mlterm-fontgen"
  echo "# Do NOT run mlfc directly — it clobbers this file (the mlfc guard blocks it)."
  echo "# Family names are portable across machines."
  echo "DEFAULT = $primary"
  grep -E '^(ISO10646_UCS4_1=|U\+)' "$gen"
} > "$tmp"
mv "$tmp" "$AAFONT"

ranges="$(grep -c '^U+' "$AAFONT" || true)"
echo "mlterm-fontgen: wrote $ranges fallback ranges to $AAFONT" >&2
echo "mlterm-fontgen: live now via symlink ~/.mlterm/aafont -> $AAFONT (relaunch mlterm-fb)." >&2
