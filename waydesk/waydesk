#!/usr/bin/env bash
# waydesk — remote Wayland desktop over waypipe + ssh, detached and tracked.
#
# Brings up a remote desktop session (a nested compositor shipped through
# waypipe) and forks it into its own session, so your terminal is freed and the
# desktop is not tied to the launching shell. LAN/VPN use — plain ssh transport,
# no relay, no STUN. Reciprocal by nature: any box can reach any other
# (north <-> slab <-> cube).
#
# Sessions are tracked on BOTH ends so they can be listed and torn down cleanly,
# and so a second launch to the same host doesn't silently stack another copy
# (each nested desktop fights the others for keyboard focus locally):
#
#   waydesk [user@]host [-d NAME] [-- remote-command ...]   launch a desktop
#   waydesk list                                  list running sessions
#   waydesk stop <host|--all>                     tear a session down cleanly
#   waydesk desktops                              list the built-in desktop presets
#
# Desktops are named presets (-d NAME): plasma, sway, labwc, lxqt. Each preset
# bakes in the remote launch command, the env a NESTED compositor needs to render
# in software (no GPU under it), and a sane default for waypipe. The minimal
# wlroots compositors (sway/labwc/lxqt) are software-rendered, so their preset
# defaults waypipe to --no-gpu — which is both correct (nothing to forward) and
# the thing that stops waypipe segfaulting on a host's dmabuf/NVIDIA path. Plasma
# is a full DE: it works, but it's heavy and brings its own service swarm; the
# minimal compositors are the well-behaved choice over waypipe.
#
# `-- cmd` still overrides everything: it runs your command verbatim, no preset
# env, for anything the presets don't cover.
#
# Tracking: the local waypipe+ssh runs in its own process group (setsid), and
# the remote desktop is wrapped so it records its OWN process-group id into a
# per-session runfile on the target. `stop` kills the local group AND ssh's in
# to kill exactly that remote group — so it tears down the nested desktop we
# launched, and never a physical seat0 session on that machine. Dead sessions
# are garbage-collected on every invocation.
#
# Examples:
#   waydesk slab                  # default desktop on slab, as $USER
#   waydesk bockeliea@slab        # default desktop on slab, explicit remote user
#   waydesk cube -d labwc         # labwc (recommended minimal desktop) on cube
#   waydesk cube -d lxqt          # LXQt desktop (on labwc) on cube
#   waydesk north -d sway         # sway tiling compositor on north
#   waydesk north -- foot         # run an arbitrary command, no preset
#   waydesk list                  # what's running
#   waydesk stop slab             # tear it down  (waydesk stop --all for every one)
#
# Tunables (env):
#   WAYDESK_DESKTOP        default preset when -d is omitted (default: plasma)
#   WAYDESK_WAYPIPE_OPTS   waypipe flags; overrides the preset's default entirely
#                          (preset default: --compress=lz4, plus --no-gpu for the
#                          software-rendered wlroots presets)

set -euo pipefail
shopt -s nullglob

rundir="${XDG_CACHE_HOME:-$HOME/.cache}/waydesk"

usage() {
  cat >&2 <<'EOF'
usage: waydesk [user@]host [-d NAME] [-- remote-command ...]   launch a desktop
       waydesk list                                  list running sessions
       waydesk stop <host|--all>                     tear a session down
       waydesk desktops                              list desktop presets (-d NAME)
EOF
  exit "${1:-0}"
}

# --- desktop presets --------------------------------------------------------
# A preset names everything a NESTED compositor needs over waypipe: the remote
# launch command, the probe binary preflight checks for, the env that forces
# software (pixman) rendering — wlroots compositors otherwise try the GPU under
# them, which has nothing to render into here — and whether it's software-rendered
# (those default waypipe to --no-gpu). Resolving a preset sets the preset_* vars.
#
# WLR_RENDERER=pixman + WLR_NO_HARDWARE_CURSORS=1 is the exact pair proven stable
# for nested wlroots over `waypipe --no-gpu` on these hosts.
desktop_preset() {  # name -> preset_cmd / preset_probe / preset_env / preset_soft
  local soft_env='WLR_RENDERER=pixman WLR_NO_HARDWARE_CURSORS=1'
  case "$1" in
    plasma|kde)
      preset_cmd='dbus-run-session startplasma-wayland'
      preset_probe='startplasma-wayland'; preset_env=''; preset_soft=0 ;;
    sway)
      preset_cmd='sway'
      preset_probe='sway'; preset_env="$soft_env"; preset_soft=1 ;;
    labwc)
      preset_cmd='labwc'
      preset_probe='labwc'; preset_env="$soft_env"; preset_soft=1 ;;
    lxqt)
      # startlxqtwayland reads ~/.config/lxqt/session.conf for compositor=labwc
      # (one-time setup on the target); the soft_env propagates into that labwc.
      preset_cmd='startlxqtwayland'
      preset_probe='startlxqtwayland'; preset_env="$soft_env"; preset_soft=1 ;;
    *) return 1 ;;
  esac
}

cmd_desktops() {
  cat <<'EOF'
waydesk desktop presets   (waydesk HOST -d NAME)

  NAME     KIND                                   REMOTE COMMAND
  plasma   KDE Plasma — full DE, heavy            dbus-run-session startplasma-wayland
  sway     wlroots, tiling — rock-stable here     sway
  labwc    wlroots, stacking — recommended        labwc
  lxqt     LXQt desktop on labwc                   startlxqtwayland

sway/labwc/lxqt are software-rendered (pixman) and default waypipe to --no-gpu.
plasma is the default when -d is omitted; set WAYDESK_DESKTOP to change that.
Override the remote command entirely (no preset) with:  waydesk HOST -- your-command
EOF
}

# --- session bookkeeping ----------------------------------------------------
# Each local runfile is "<host>.pid" holding one line:  <local_pgid> <sid> <target>
#   local_pgid  process group of the local waypipe+ssh (setsid leader)
#   sid         session id; names the runfile the remote desktop writes its pgid into
#   target      user@host, for the teardown ssh

pidfile() { printf '%s/%s.pid' "$rundir" "$1"; }

# POSIX single-quote a string so it survives one round of remote-shell parsing.
shquote() { local s=${1//\'/\'\\\'\'}; printf "'%s'" "$s"; }

# True if the recorded local session is running AND is still our waypipe — the
# cmdline check guards against a recycled PID passing as live (which would let
# `stop` group-kill an unrelated process and dedup refuse falsely).
alive() {  # host
  local pf pid; pf="$(pidfile "$1")"
  [[ -f "$pf" ]] || return 1
  read -r pid _ < "$pf" 2>/dev/null || return 1
  [[ -n "${pid:-}" ]] || return 1
  kill -0 "$pid" 2>/dev/null || return 1
  grep -qa waypipe "/proc/$pid/cmdline" 2>/dev/null
}

# Drop runfiles whose local process is gone — garbage-collect dead sessions.
gc() {
  local pf
  for pf in "$rundir"/*.pid; do
    alive "$(basename "$pf" .pid)" || rm -f "$pf"
  done
}

cmd_list() {
  gc
  local pf host pid sid tgt et found=0
  for pf in "$rundir"/*.pid; do
    host="$(basename "$pf" .pid)"; read -r pid sid tgt < "$pf" 2>/dev/null || continue
    et="$(ps -o etime= -p "$pid" 2>/dev/null | tr -d ' ')"
    [[ "$found" == 0 ]] && printf '%-16s %-8s %-10s %s\n' HOST PID UPTIME TARGET
    printf '%-16s %-8s %-10s %s\n' "$host" "$pid" "${et:-?}" "${tgt:-?}"
    found=1
  done
  [[ "$found" == 1 ]] || echo "waydesk: no active sessions"
}

# Kill the remote desktop we launched, by the pgid it recorded — only that one.
reap_remote() {  # target sid
  local tgt="$1" sid="$2" rk
  [[ -n "$tgt" && -n "$sid" ]] || return 0
  # Runs under the remote login shell; POSIX, evaluated remotely. `sid` is baked
  # in; $HOME/$f/$p are remote. Negative pid = the whole nested-desktop group.
  rk='f="$HOME/.cache/waydesk/'"$sid"'.pgid"; if [ -f "$f" ]; then IFS= read -r p < "$f"; kill -- "-$p" 2>/dev/null && echo "  remote desktop ended (pgid $p)"; rm -f "$f"; else echo "  no remote runfile (already gone)"; fi'
  if ! ssh -o BatchMode=yes -o ConnectTimeout=10 \
          -o ServerAliveInterval=5 -o ServerAliveCountMax=3 "$tgt" "$rk"; then
    echo "waydesk: warning: couldn't reach $tgt — nested desktop may still run there" >&2
  fi
}

stop_host() {  # host
  local pf pid sid tgt; pf="$(pidfile "$1")"
  if [[ ! -f "$pf" ]]; then echo "waydesk: no session for $1" >&2; return 1; fi
  read -r pid sid tgt < "$pf" 2>/dev/null || true
  # local: kill the whole group so waypipe and its ssh go down together — but
  # only while the PID is still our waypipe, so a recycled PID is never group-killed
  if [[ -n "${pid:-}" ]] && kill -0 "$pid" 2>/dev/null \
       && grep -qa waypipe "/proc/$pid/cmdline" 2>/dev/null; then
    kill -- "-$pid" 2>/dev/null || kill "$pid" 2>/dev/null
    echo "waydesk: stopped $1 local tunnel (pgid $pid)"
  else
    echo "waydesk: $1 local tunnel was not running"
  fi
  reap_remote "${tgt:-}" "${sid:-}" || true   # best-effort; never block local cleanup
  rm -f "$pf"
}

cmd_stop() {
  [[ $# -ge 1 ]] || { echo "waydesk: stop needs a host or --all" >&2; exit 1; }
  if [[ "$1" == "--all" ]]; then
    local pf
    for pf in "$rundir"/*.pid; do stop_host "$(basename "$pf" .pid)" || true; done
    return 0
  fi
  stop_host "${1#*@}"   # accept user@host too
}

# --- dispatch ---------------------------------------------------------------

mkdir -p "$rundir"

[[ $# -ge 1 ]] || usage 1
case "$1" in
  -h|--help|help) usage 0 ;;
  list|ls)        cmd_list; exit 0 ;;
  stop|kill)      shift; cmd_stop "$@"; exit 0 ;;
  desktops)       cmd_desktops; exit 0 ;;
esac

# --- launch -----------------------------------------------------------------

# Parse the launch line: the host (first positional), an optional -d NAME, and an
# optional `-- cmd...` passthrough. `--` ends option parsing and overrides the
# preset entirely.
target=""; desktop=""; remote_cmd=(); explicit=0
while [[ $# -gt 0 ]]; do
  case "$1" in
    -d|--desktop) [[ -n "${2:-}" ]] || { echo "waydesk: -d needs a desktop name" >&2; exit 1; }
                  desktop="$2"; shift 2 ;;
    --)           shift; remote_cmd=( "$@" ); explicit=1; break ;;
    -h|--help)    usage 0 ;;
    -*)           echo "waydesk: unknown option: $1" >&2; usage 1 ;;
    *)            if [[ -z "$target" ]]; then target="$1"; shift
                  else echo "waydesk: unexpected argument: $1" >&2; usage 1; fi ;;
  esac
done
[[ -n "$target" ]] || usage 1
[[ "$target" == *@* ]] || target="$USER@$target"
host="${target#*@}"

# Resolve the remote command. An explicit `-- cmd` wins and runs verbatim — no
# preset env, no probe. Otherwise use the named preset (or WAYDESK_DESKTOP, or
# plasma) and prepend its software-render env.
preset_probe=""; preset_soft=0
if (( explicit )); then
  [[ ${#remote_cmd[@]} -ge 1 ]] || { echo "waydesk: no command given after --" >&2; exit 1; }
else
  desktop="${desktop:-${WAYDESK_DESKTOP:-plasma}}"
  if ! desktop_preset "$desktop"; then
    echo "waydesk: unknown desktop '$desktop' — try: waydesk desktops" >&2
    exit 1
  fi
  # word-splitting is intentional: preset_env is "VAR=v VAR=v", preset_cmd may be
  # multiple words (e.g. dbus-run-session startplasma-wayland).
  # shellcheck disable=SC2206
  if [[ -n "$preset_env" ]]; then remote_cmd=( env $preset_env $preset_cmd )
  else remote_cmd=( $preset_cmd ); fi
fi

# garbage-collect dead sessions, then refuse to stack a second one on this host
gc
if alive "$host"; then
  read -r existing _ < "$(pidfile "$host")" 2>/dev/null || true
  echo "waydesk: a session to $host is already running (pid $existing)." >&2
  echo "         stop it first:  waydesk stop $host" >&2
  exit 1
fi

# we display into the LOCAL compositor — it must exist
[[ -n "${WAYLAND_DISPLAY:-}" ]] || {
  echo "waydesk: no WAYLAND_DISPLAY — run from inside your local Wayland session" >&2
  exit 1
}

# preflight: every local tool waydesk drives must be present. Report all the
# missing ones at once, each with the package that provides it.
missing=()
for need in "waypipe:waypipe" "ssh:openssh" "setsid:util-linux"; do
  cmd="${need%%:*}"; pkg="${need##*:}"
  command -v "$cmd" >/dev/null 2>&1 || missing+=("$cmd (install: $pkg)")
done
if (( ${#missing[@]} )); then
  echo "waydesk: missing required local tool(s):" >&2
  printf '  - %s\n' "${missing[@]}" >&2
  exit 1
fi

# waypipe opts: an explicit WAYDESK_WAYPIPE_OPTS overrides everything. Otherwise
# start from --compress=lz4 and, for a software-rendered preset, add --no-gpu —
# there's nothing under a pixman compositor to forward, and forwarding it is the
# path that segfaults waypipe on quirky dmabuf/NVIDIA hosts.
if [[ -n "${WAYDESK_WAYPIPE_OPTS:-}" ]]; then
  read -r -a wp_opts <<< "$WAYDESK_WAYPIPE_OPTS"
else
  wp_opts=( --compress=lz4 )
  (( preset_soft )) && wp_opts+=( --no-gpu )
fi

# session id names the remote runfile; uniqueness across source hosts + launches
lhost="${HOSTNAME:-$(uname -n 2>/dev/null || echo host)}"; lhost="${lhost%%.*}"
sid="${lhost}-$(date +%s)-$RANDOM"

# The remote work must be waypipe's OWN forwarded command, so it ALL runs inside
# one `sh -c '…'`. If we instead sent `mkdir …; setsid desktop & …`, the target's
# ssh shell would parse the `;`/`&` and waypipe would wrap only the first word —
# the desktop would then run OUTSIDE the forwarded display (it launches, but no
# window appears). Single-quoting hands the whole script to that one sh, so the
# desktop and everything it spawns inherit waypipe's WAYLAND_DISPLAY.
#
# Inside (run by the remote sh): start the desktop in its own session, record its
# pgid, then wait. The shell is non-interactive (no job control), so `setsid CMD &`
# does not fork — $! is the new session leader, whose pgid equals its pid, so it's
# exactly the group `stop` kills. `sid`/command bake in locally; $HOME/$!/$p
# evaluate on the target.
rpf="\$HOME/.cache/waydesk/${sid}.pgid"
# For a preset, preflight the desktop binary on the target so a missing one is a
# clear line in the log instead of a silent black screen. (No probe for `-- cmd`.)
probe=""
[[ -n "$preset_probe" ]] && probe="command -v $(shquote "$preset_probe") >/dev/null 2>&1 || { echo \"waydesk: $preset_probe not found on $host\" >&2; exit 127; }; "
script="mkdir -p \"\$HOME/.cache/waydesk\"; ${probe}setsid ${remote_cmd[*]} & p=\$!; echo \$p > \"$rpf\"; wait \$p; rm -f \"$rpf\""
remote_str="sh -c $(shquote "$script")"

log="$rundir/$host.log"
echo "waydesk → $target : ${explicit:+(custom) }${desktop:+[$desktop] }${remote_cmd[*]}"
echo "          waypipe: ${wp_opts[*]}"
echo "          log: $log"

# Own session/process group (setsid, no -f so the leader PID is the one we keep)
# for the local waypipe+ssh; record pgid + sid + target so `stop` tears down
# both ends.
setsid waypipe "${wp_opts[@]}" ssh "$target" "$remote_str" >"$log" 2>&1 </dev/null &
pid=$!
printf '%s %s %s\n' "$pid" "$sid" "$target" > "$(pidfile "$host")"

echo "launched (detached, pid $pid) — closing this terminal won't kill it."
echo "stop with:  waydesk stop $host   ·   list:  waydesk list"
