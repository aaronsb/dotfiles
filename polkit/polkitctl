#!/usr/bin/env bash
# polkitctl — lifecycle for passive polkit fragments tracked in the dotfiles repo.
#
# Fragments live in  <repo>/polkit/rules/*.rules  and are INERT until applied.
# This script is the ONLY thing that touches /etc, and never implicitly: it is
# not wired into `dotfiles deploy`, so activating a privileged rule is always an
# explicit, sudo'd act on the machine you are sitting on.
#
# Verbs:
#   status              table of every tracked fragment + state (default)
#   apply <name|--all>  install fragment(s) -> /etc/polkit-1/rules.d (root:root 0644)
#   remove <name>       remove the deployed copy (repo source untouched)
#   diff <name>         repo source vs the live /etc copy
#
# Scope is deliberately single-host and manual. There is NO per-host desired
# state and NO convergence/sync — that is the line into fleet management, and
# we keep it on the far side of it on purpose.

set -euo pipefail

self="$(readlink -f "${BASH_SOURCE[0]}")"
rules_dir="$(dirname "$self")/rules"
etc_dir="/etc/polkit-1/rules.d"

die()   { printf 'polkitctl: %s\n' "$*" >&2; exit 1; }
usage() {
  cat >&2 <<'EOF'
usage: polkitctl [status]                 list tracked fragments + state
       polkitctl apply <name|--all>       install to /etc/polkit-1/rules.d
       polkitctl remove <name>            remove the deployed copy
       polkitctl diff <name>              repo source vs live /etc copy
EOF
  exit "${1:-0}"
}

# normalize a fragment arg to a bare filename ending in .rules
norm() { local n="$1"; [[ "$n" == *.rules ]] || n="$n.rules"; printf '%s' "$n"; }

tracked()  { find "$rules_dir" -maxdepth 1 -name '*.rules' -printf '%f\n' 2>/dev/null | sort; }
deployed() { sudo find "$etc_dir" -maxdepth 1 -name '*.rules' -printf '%f\n' 2>/dev/null | sort; }

state_of() {
  local f="$1" src="$rules_dir/$1" dst="$etc_dir/$1"
  if ! sudo test -e "$dst";        then echo INACTIVE
  elif sudo cmp -s "$src" "$dst";  then echo ACTIVE
  else                                  echo DRIFTED; fi
}

cmd_status() {
  printf '%-36s %s\n' NAME STATE
  printf '%-36s %s\n' '----' '-----'
  local f
  while IFS= read -r f; do
    [[ -n "$f" ]] && printf '%-36s %s\n' "$f" "$(state_of "$f")"
  done < <(tracked)
  # rules present in /etc with no repo source — reported, never auto-touched
  local d
  while IFS= read -r d; do
    [[ -n "$d" && ! -e "$rules_dir/$d" ]] && printf '%-36s %s\n' "$d" UNTRACKED
  done < <(deployed)
}

cmd_apply() {
  [[ $# -ge 1 ]] || usage 1
  local list
  if [[ "$1" == "--all" ]]; then list="$(tracked)"; else list="$(norm "$1")"; fi
  local f
  while IFS= read -r f; do
    [[ -n "$f" ]] || continue
    [[ -e "$rules_dir/$f" ]] || die "no such fragment: $f"
    sudo install -o root -g root -m 0644 "$rules_dir/$f" "$etc_dir/$f"
    echo "applied  $f"
  done <<< "$list"
  echo "(polkitd reloads rules.d automatically — no restart needed)"
}

cmd_remove() {
  [[ $# -ge 1 ]] || usage 1
  local f; f="$(norm "$1")"
  if ! sudo test -e "$etc_dir/$f"; then echo "not active: $f"; return 0; fi
  sudo rm -f "$etc_dir/$f"
  echo "removed  $f"
}

cmd_diff() {
  [[ $# -ge 1 ]] || usage 1
  local f; f="$(norm "$1")"
  [[ -e "$rules_dir/$f" ]] || die "no such fragment: $f"
  if ! sudo test -e "$etc_dir/$f"; then echo "inactive (not deployed): $f"; return 0; fi
  if sudo diff -u "$etc_dir/$f" "$rules_dir/$f"; then echo "(identical)"; fi
}

case "${1:-status}" in
  status|ls|list) cmd_status ;;
  apply)          shift; cmd_apply  "$@" ;;
  remove|rm)      shift; cmd_remove "$@" ;;
  diff)           shift; cmd_diff   "$@" ;;
  -h|--help|help) usage 0 ;;
  *)              die "unknown verb: $1 (try: status|apply|remove|diff)" ;;
esac
