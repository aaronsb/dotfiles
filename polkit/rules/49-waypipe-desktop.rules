// 49-waypipe-desktop.rules
//
// Grant the wheel group the everyday desktop privileges that a LOCAL ACTIVE
// session gets silently, so a waypipe-nested / ssh-launched Plasma session
// (which logind classifies as Remote=yes, seat-less -> polkit "allow_any")
// does not prompt for a password on routine actions.
//
// Why this and not a logind fix: a remote ssh session cannot be made
// local-active -- seat0 is owned by the physical session, and logind permits
// one active session per seat. polkit rules are the supported override.
//
// Scope: wheel only, limited to the action prefixes a desktop session uses.
// Tradeoff: any wheel member can do these without a password from any session.
// Acceptable on a single-user homelab box (passwordless sudo already set).
polkit.addRule(function(action, subject) {
    if (!subject.isInGroup("wheel")) return;

    var allow = [
        "org.freedesktop.NetworkManager.",
        "org.freedesktop.UDisks2.",
        "org.freedesktop.login1.",
        "org.freedesktop.ModemManager1.",
        "org.freedesktop.color-manager."
    ];
    for (var i = 0; i < allow.length; i++) {
        if (action.id.indexOf(allow[i]) === 0)
            return polkit.Result.YES;
    }
});
